rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && firestore.exists(/databases/(default)/documents/users/$(request.auth.uid))
        && (
          firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.isAdmin == true
          || firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin'
        );
    }

    // DEBUG TEMPORAL (solo mientras diagnosticas):
    // match /{allPaths=**} {
    //   allow read: if true;
    //   allow write: if isSignedIn();
    // }

    // Producción recomendada: medios solo para admins autenticados.
    match /propiedades/{propertyId}/{mediaFolder}/{fileName} {
      allow read: if true;
      allow write: if isAdmin()
        && propertyId.size() > 0
        && (mediaFolder == 'imagenes' || mediaFolder == 'videos')
        && fileName.size() > 0;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
