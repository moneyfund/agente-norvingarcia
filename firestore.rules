rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uidField) {
      return isSignedIn() && request.resource.data[uidField] == request.auth.uid;
    }

    function isResourceOwner(uidField) {
      return isSignedIn() && resource.data[uidField] == request.auth.uid;
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && request.auth.uid == userId;
      allow delete: if false;
    }

    match /propiedades/{propertyId} {
      allow read: if true;
      allow write: if false;
    }

    match /likes/{likeId} {
      allow read: if true;
      allow create: if isOwner('uid');
      allow delete: if isResourceOwner('uid');
      allow update: if false;
    }

    match /comments/{commentId} {
      allow read: if true;
      allow create: if isOwner('uid');
      allow update, delete: if isResourceOwner('uid');
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create, update: if isOwner('uid');
      allow delete: if isResourceOwner('uid');
    }

    match /protectedForms/{submissionId} {
      allow read: if isSignedIn();
      allow create: if isOwner('uid');
      allow update, delete: if false;
    }
  }
}
