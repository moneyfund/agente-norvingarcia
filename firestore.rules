rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isTimestampOrServerTimestamp(field) {
      return field is timestamp || field == request.time;
    }

    function hasValidUserProfileFields() {
      return request.resource.data.uid == request.auth.uid
        && request.resource.data.userName is string
        && request.resource.data.userName.size() > 0
        && request.resource.data.userEmail is string
        && request.resource.data.userEmail.size() > 0
        && (request.resource.data.userPhotoURL == null || request.resource.data.userPhotoURL is string);
    }

    function hasValidCommentShape(propertyId) {
      return request.resource.data.keys().hasOnly([
          'uid', 'userName', 'userEmail', 'userPhotoURL', 'content', 'propertyId', 'createdAt', 'updatedAt'
        ])
        && hasValidUserProfileFields()
        && request.resource.data.content is string
        && request.resource.data.content.size() > 0
        && request.resource.data.propertyId == propertyId
        && isTimestampOrServerTimestamp(request.resource.data.createdAt)
        && isTimestampOrServerTimestamp(request.resource.data.updatedAt);
    }

    function hasValidReviewShape(propertyId) {
      return request.resource.data.keys().hasOnly([
          'uid', 'userName', 'userEmail', 'userPhotoURL', 'rating', 'content', 'propertyId', 'createdAt', 'updatedAt'
        ])
        && hasValidUserProfileFields()
        && request.resource.data.rating is number
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5
        && request.resource.data.content is string
        && request.resource.data.content.size() > 0
        && request.resource.data.propertyId == propertyId
        && isTimestampOrServerTimestamp(request.resource.data.createdAt)
        && isTimestampOrServerTimestamp(request.resource.data.updatedAt);
    }

    function hasValidLikeShape(propertyId) {
      return request.resource.data.keys().hasOnly(['uid', 'propertyId', 'createdAt'])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.propertyId == propertyId
        && isTimestampOrServerTimestamp(request.resource.data.createdAt);
    }

    function hasValidPropertyFormShape(propertyId) {
      return request.resource.data.keys().hasOnly([
          'uid', 'userName', 'userEmail', 'userPhotoURL', 'phone', 'message', 'propertyId', 'createdAt', 'status'
        ])
        && hasValidUserProfileFields()
        && request.resource.data.phone is string
        && request.resource.data.phone.size() > 0
        && request.resource.data.message is string
        && request.resource.data.message.size() > 0
        && request.resource.data.propertyId == propertyId
        && request.resource.data.status == 'nuevo'
        && isTimestampOrServerTimestamp(request.resource.data.createdAt);
    }

    function hasValidGeneralFormShape() {
      return request.resource.data.keys().hasOnly([
          'uid', 'userName', 'userEmail', 'userPhotoURL', 'phone', 'message', 'createdAt', 'status'
        ])
        && hasValidUserProfileFields()
        && request.resource.data.phone is string
        && request.resource.data.phone.size() > 0
        && request.resource.data.message is string
        && request.resource.data.message.size() > 0
        && request.resource.data.status == 'nuevo'
        && isTimestampOrServerTimestamp(request.resource.data.createdAt);
    }

    match /users/{uid} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(uid) && request.resource.data.uid == request.auth.uid;
      allow delete: if false;
    }

    match /agentes/{agenteId} {
      allow read: if true;
      allow create, update: if isSignedIn();
      allow delete: if false;
    }

    match /propiedades/{propertyId} {
      allow read: if true;
      allow write: if false;

      match /comentarios/{commentId} {
        allow read: if true;
        allow create: if isSignedIn() && hasValidCommentShape(propertyId);
        allow update, delete: if isSignedIn() && resource.data.uid == request.auth.uid;
      }

      match /resenas/{reviewId} {
        allow read: if true;
        allow create: if isSignedIn() && hasValidReviewShape(propertyId);
        allow update, delete: if isSignedIn() && resource.data.uid == request.auth.uid;
      }

      match /likes/{uid} {
        allow read: if true;
        allow create: if isOwner(uid) && hasValidLikeShape(propertyId);
        allow delete: if isOwner(uid);
        allow update: if false;
      }

      match /formularios/{formId} {
        allow create: if isSignedIn() && hasValidPropertyFormShape(propertyId);
        allow read: if isSignedIn() && resource.data.uid == request.auth.uid;
        allow update, delete: if false;
      }
    }

    match /formularios/{formId} {
      allow create: if isSignedIn() && hasValidGeneralFormShape();
      allow read: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }
  }
}
