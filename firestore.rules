rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function sameUid(fieldName) {
      return isSignedIn() && request.resource.data[fieldName] == request.auth.uid;
    }

    function isResourceOwner(fieldName) {
      return isSignedIn() && resource.data[fieldName] == request.auth.uid;
    }

    match /users/{uid} {
      allow read: if isSignedIn();
      allow create, update: if isSelf(uid) && sameUid('uid');
      allow delete: if false;
    }

    match /agentes/{agenteId} {
      allow read: if true;
      allow create, update: if isSignedIn();
      allow delete: if false;
    }

    match /propiedades/{propertyId} {
      allow read: if true;
      allow write: if false;

      match /likes/{uid} {
        allow read: if true;
        allow create: if isSelf(uid) && sameUid('uid') && request.resource.data.propertyId == propertyId;
        allow delete: if isSelf(uid) && isResourceOwner('uid');
        allow update: if false;
      }

      match /comentarios/{commentId} {
        allow read: if true;
        allow create: if sameUid('uid') && request.resource.data.propertyId == propertyId;
        allow update, delete: if isResourceOwner('uid');
      }

      match /resenas/{uid} {
        allow read: if true;
        allow create, update: if isSelf(uid) && sameUid('uid') && request.resource.data.propertyId == propertyId;
        allow delete: if isSelf(uid) && isResourceOwner('uid');
      }

      match /formularios/{formId} {
        allow read: if isSignedIn() && isResourceOwner('uid');
        allow create: if sameUid('uid') && request.resource.data.propertyId == propertyId;
        allow update, delete: if false;
      }
    }

    match /formularios_generales/{formId} {
      allow read: if isSignedIn() && isResourceOwner('uid');
      allow create: if sameUid('uid');
      allow update, delete: if false;
    }
  }
}
