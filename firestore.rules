rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isValidBaseUserFields() {
      return request.resource.data.uid == request.auth.uid
        && request.resource.data.userName is string
        && request.resource.data.userEmail is string;
    }

    function isValidComment(propertyId) {
      return request.resource.data.keys().hasOnly([
          'uid', 'userName', 'userEmail', 'userPhotoURL', 'content', 'propertyId', 'createdAt', 'updatedAt'
        ])
        && isValidBaseUserFields()
        && request.resource.data.userPhotoURL is string
        && request.resource.data.content is string
        && request.resource.data.content.size() > 0
        && request.resource.data.propertyId == propertyId;
    }

    function isValidReview(propertyId) {
      return request.resource.data.keys().hasOnly([
          'uid', 'userName', 'userEmail', 'userPhotoURL', 'rating', 'content', 'propertyId', 'createdAt', 'updatedAt'
        ])
        && isValidBaseUserFields()
        && request.resource.data.userPhotoURL is string
        && request.resource.data.rating is number
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5
        && request.resource.data.content is string
        && request.resource.data.content.size() > 0
        && request.resource.data.propertyId == propertyId;
    }

    function isValidPropertyForm(propertyId) {
      return request.resource.data.keys().hasOnly([
          'uid', 'userName', 'userEmail', 'phone', 'message', 'propertyId', 'createdAt', 'status'
        ])
        && isValidBaseUserFields()
        && request.resource.data.phone is string
        && request.resource.data.phone.size() > 0
        && request.resource.data.message is string
        && request.resource.data.message.size() > 0
        && request.resource.data.status is string
        && request.resource.data.propertyId == propertyId;
    }

    function isValidGeneralForm() {
      return request.resource.data.keys().hasOnly([
          'uid', 'userName', 'userEmail', 'phone', 'message', 'createdAt', 'status'
        ])
        && isValidBaseUserFields()
        && request.resource.data.phone is string
        && request.resource.data.phone.size() > 0
        && request.resource.data.message is string
        && request.resource.data.message.size() > 0
        && request.resource.data.status is string;
    }

    match /users/{uid} {
      allow read: if isSignedIn();
      allow create, update: if isSelf(uid) && request.resource.data.uid == request.auth.uid;
      allow delete: if false;
    }

    match /agentes/{agenteId} {
      allow read: if true;
      allow create, update: if isSignedIn();
      allow delete: if false;
    }

    match /propiedades/{propertyId} {
      allow read: if true;
      allow write: if false;

      match /comentarios/{commentId} {
        allow read: if true;
        allow create: if isSignedIn() && isValidComment(propertyId);
        allow update: if isSignedIn()
          && resource.data.uid == request.auth.uid
          && isValidComment(propertyId)
          && request.resource.data.uid == resource.data.uid
          && request.resource.data.propertyId == resource.data.propertyId;
        allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
      }

      match /resenas/{reviewId} {
        allow read: if true;
        allow create: if isSignedIn() && isValidReview(propertyId);
        allow update: if isSignedIn()
          && resource.data.uid == request.auth.uid
          && isValidReview(propertyId)
          && request.resource.data.uid == resource.data.uid
          && request.resource.data.propertyId == resource.data.propertyId;
        allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
      }

      match /likes/{uid} {
        allow read: if true;
        allow create: if isSelf(uid)
          && request.resource.data.keys().hasOnly(['uid', 'propertyId', 'createdAt'])
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.propertyId == propertyId;
        allow delete: if isSelf(uid) && resource.data.uid == request.auth.uid;
        allow update: if false;
      }

      match /formularios/{formId} {
        allow read: if isSignedIn() && resource.data.uid == request.auth.uid;
        allow create: if isSignedIn() && isValidPropertyForm(propertyId);
        allow update, delete: if false;
      }
    }

    match /formularios/{formId} {
      allow read: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow create: if isSignedIn() && isValidGeneralForm();
      allow update, delete: if false;
    }
  }
}
