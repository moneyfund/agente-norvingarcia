rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function hasCommonUserFields() {
      return request.resource.data.uid == request.auth.uid
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.userName is string
        && request.resource.data.userEmail is string
        && request.resource.data.userPhotoURL is string;
    }

    function hasOnlyCommentFields() {
      return request.resource.data.keys().hasOnly([
        'uid', 'userId', 'userName', 'userEmail', 'userPhotoURL', 'propertyId', 'message', 'createdAt', 'updatedAt', 'status'
      ]);
    }

    function hasOnlyReviewFields() {
      return request.resource.data.keys().hasOnly([
        'uid', 'userId', 'userName', 'userEmail', 'userPhotoURL', 'propertyId', 'message', 'rating', 'createdAt', 'updatedAt', 'status'
      ]);
    }

    function hasOnlyPropertyFormFields() {
      return request.resource.data.keys().hasOnly([
        'uid', 'userId', 'userName', 'userEmail', 'userPhotoURL', 'propertyId', 'content', 'createdAt', 'updatedAt', 'status'
      ]);
    }

    function hasOnlyGeneralFormFields() {
      return request.resource.data.keys().hasOnly([
        'uid', 'userId', 'userName', 'userEmail', 'userPhotoURL', 'content', 'createdAt', 'updatedAt', 'status'
      ]);
    }

    match /users/{uid} {
      allow read: if isSignedIn();
      allow create, update: if isSelf(uid) && request.resource.data.uid == request.auth.uid;
      allow delete: if false;
    }

    match /agentes/{agenteId} {
      allow read: if true;
      allow create, update: if isSignedIn();
      allow delete: if false;
    }

    match /propiedades/{propertyId} {
      allow read: if true;
      allow write: if false;

      match /likes/{uid} {
        allow read: if true;
        allow create: if isSelf(uid)
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.propertyId == propertyId;
        allow delete: if isSelf(uid) && resource.data.uid == request.auth.uid;
        allow update: if false;
      }

      match /comentarios/{commentId} {
        allow read: if true;
        allow create: if isSignedIn()
          && hasCommonUserFields()
          && hasOnlyCommentFields()
          && request.resource.data.propertyId == propertyId
          && request.resource.data.message is string;
        allow update, delete: if isSignedIn() && resource.data.uid == request.auth.uid;
      }

      match /resenas/{reviewId} {
        allow read: if true;
        allow create: if isSignedIn()
          && hasCommonUserFields()
          && hasOnlyReviewFields()
          && request.resource.data.propertyId == propertyId
          && request.resource.data.message is string
          && request.resource.data.rating is number
          && request.resource.data.rating >= 1
          && request.resource.data.rating <= 5;
        allow update, delete: if isSignedIn() && resource.data.uid == request.auth.uid;
      }

      match /formularios/{formId} {
        allow read: if isSignedIn() && resource.data.uid == request.auth.uid;
        allow create: if isSignedIn()
          && hasCommonUserFields()
          && hasOnlyPropertyFormFields()
          && request.resource.data.propertyId == propertyId
          && request.resource.data.content is map;
        allow update, delete: if false;
      }
    }

    match /formularios/{formId} {
      allow read: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow create: if isSignedIn()
        && hasCommonUserFields()
        && hasOnlyGeneralFormFields()
        && request.resource.data.content is map;
      allow update, delete: if false;
    }
  }
}
